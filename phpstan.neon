includes:
    - vendor/larastan/larastan/extension.neon
    - vendor/nesbot/carbon/extension.neon

parameters:
    paths:
        - app/
        - bootstrap/app.php
        - config/
        - database/
        - routes/

    level: 7

    ignoreErrors:
        - '#Class App\\Models\\(AuthorProfile|Collection|HeroSection|Writing) uses generic trait Illuminate\\Database\\Eloquent\\Factories\\HasFactory but does not specify its types#'
